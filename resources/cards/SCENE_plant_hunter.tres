[sub_resource type="Resource" id="req_sdt"]
script = ExtResource("3")
accept_card_ids = Array[String](["ITEM_sdt"])
hint = "需要手电筒"

[sub_resource type="Resource" id="req_coin"]
script = ExtResource("3")
accept_card_ids = Array[String](["ITEM_coin"])
hint = "需要因果律"

[sub_resource type="Resource" id="branch_collect"]
script = ExtResource("6")
branch_name = "采集"
required_cards = Array[ExtResource("3")]([SubResource("req_sdt"), SubResource("req_coin")])
result_recipes = Array[ExtResource("8")]([ExtResource("4")])

[sub_resource type="Resource" id="req_investigator"]
script = ExtResource("3")
accept_card_ids = Array[String](["CHAR_junior_investigator"])
hint = "需要初级调查员"

[sub_resource type="Resource" id="branch_investigate"]
script = ExtResource("6")
branch_name = "调查"
required_cards = Array[ExtResource("3")]([SubResource("req_investigator")])
result_recipes = Array[ExtResource("8")]([ExtResource("5")])

[sub_resource type="Resource" id="exp_conf"]
script = ExtResource("2")
scene_card_id = "SCENE_plant_hunter"
scene_name = "植物学家的花园"
scene_description = "由 TEC 引导进入的异界花园。植物学家在此失踪。
放入合适的卡牌探索隐藏的秘密。"
branch_recipes = Array[ExtResource("6")]([SubResource("branch_collect"), SubResource("branch_investigate")])

[resource]
script = ExtResource("1")
card_id = "SCENE_plant_hunter"
card_name = "场景：植物学家的花园"
description = "由 TEC 引导进入的异界花园。植物学家在此失踪。
双击打开探索面板。"
card_type = 4
tags = Array[String](["scene"])
bg_color = Color(0.1, 0.4, 0.25, 1)
border_color = Color(0.2, 0.7, 0.45, 1)
icon = "🌿"
exploration_config = SubResource("exp_conf")
