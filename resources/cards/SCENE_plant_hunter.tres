[gd_resource type="Resource" format=3]

[ext_resource type="Script" path="res://scripts/card_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/exploration/exploration_config.gd" id="2"]
[ext_resource type="Script" path="res://scripts/combination_recipe.gd" id="3"]
[ext_resource type="Script" path="res://scripts/panel_slot_config.gd" id="4"]

[sub_resource type="Resource" id="r_drop"]
script = ExtResource("3")
target_id = ""
result_id = "ITEM_plant"
min_count = 1
max_count = 1
weight = 1.0
max_drops = 1

[sub_resource type="Resource" id="req_sdt"]
script = ExtResource("4")
accept_card_ids = Array[String](["ITEM_sdt"])
hint = "需要手电筒"

[sub_resource type="Resource" id="req_coin"]
script = ExtResource("4")
accept_card_ids = Array[String](["ITEM_coin"])
hint = "需要因果律"

[sub_resource type="Resource" id="exp_conf"]
script = ExtResource("2")
scene_card_id = "SCENE_plant_hunter"
scene_name = "植物学家的花园"
scene_description = "由 TEC 引导进入的异界花园。植物学家在此失踪。\n放入合适的卡牌探索隐藏的秘密。"
slot_count = 3
required_cards = [SubResource("req_sdt"), SubResource("req_coin")]
explore_duration = 3.0
result_recipes = [SubResource("r_drop")]

[resource]
script = ExtResource("1")
card_id = "SCENE_plant_hunter"
card_name = "场景：植物学家的花园"
description = "由 TEC 引导进入的异界花园。植物学家在此失踪。\n双击打开探索面板。"
card_type = 4
tags = ["scene"]
bg_color = Color(0.1, 0.4, 0.25, 1.0)
border_color = Color(0.2, 0.7, 0.45, 1.0)
icon = "🌿"
exploration_config = SubResource("exp_conf")
