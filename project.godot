; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TEC3 Godot"
config/description="卡牌探索游戏 - Godot版本"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

EventBus="*res://autoload/event_bus.gd"
RecipeRegistry="*res://autoload/recipe_registry.gd"
CardManager="*res://autoload/card_manager.gd"
DialogueSystem="*res://autoload/dialogue_system.gd"
CombinationSystem="*res://autoload/combination_system.gd"
ObservationSystem="*res://autoload/observation_system.gd"
PanelManager="*res://autoload/panel_manager.gd"
ProgressService="*res://autoload/progress_service.gd"
SFX="*res://autoload/sfx.gd"
SceneDesktopManager="*res://autoload/scene_desktop_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[rendering]

textures/canvas_textures/default_texture_filter=0
